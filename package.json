{
  "name": "practice-player",
  "version": "1.0.9",
  "description": "Practice player per esercitarsi suonando: tonalita, velocita, loop, stem, video, download YouTube",
  "author": "Gianmarco Bonan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gianmarcobonan/practice-player.git"
  },
  "main": "src/main/main.js",
  "scripts": {
    "build:renderer": "node scripts/build-renderer.mjs",
    "watch:renderer": "node scripts/build-renderer.mjs --watch",
    "fetch-binaries": "node scripts/fetch-binaries.mjs",
    "start": "npm run build:renderer && electron .",
    "build": "npm run build:renderer && electron-builder --publish never",
    "dist": "npm run build:renderer && electron-builder --publish never",
    "release": "npm run build:renderer && electron-builder --publish always -c.publish.provider=github -c.publish.releaseType=release"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "fft.js": "^4.0.4",
    "wavesurfer.js": "^7.12.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "onnxruntime-node": "^1.27.0",
    "rubberband-wasm": "^3.3.0"
  }
}
